# Copy this file to ".env.local" (local) or add these in the Vercel dashboard
# (Project → Settings → Environment Variables) before deploying.

# Your live site URL — used for SEO metadata, sitemap, robots & canonical links.
# Set this to your real domain (or the *.vercel.app URL) once deployed.
NEXT_PUBLIC_SITE_URL=https://glofihub.com

# Supabase — get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SERVER ONLY — never expose). Supabase → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay — Dashboard → Settings → API Keys (use test keys first)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
