# Copy this to ".env.local" (local) or add these in Vercel → Settings → Env Vars.

# ── PostgreSQL ── any Postgres works (Neon recommended, free & serverless).
# Format: postgres://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# ── Auth ── a long random string used to sign login sessions (JWT).
# Generate one: run `openssl rand -base64 32` or use any 40+ char random string.
JWT_SECRET=

# ── Site URL ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── First-admin setup ── used once by /api/setup?secret=...
ADMIN_SETUP_SECRET=
SETUP_ADMIN_EMAIL=admin@glofihub.com
SETUP_ADMIN_PASSWORD=
